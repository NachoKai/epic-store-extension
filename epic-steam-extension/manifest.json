{
  "manifest_version": 3,
  "name": "Steam Info Overlay for Epic (Unofficial)",
  "version": "1.0.0",
  "description": "Unofficial. Shows matching Steam reviews and price on Epic Games Store product pages. Not affiliated with Valve or Epic Games.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://store.epicgames.com/*",
    "https://store.steampowered.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://store.epicgames.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Steam Info Overlay for Epic (Unofficial)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
